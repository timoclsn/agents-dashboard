{
  "name": "agents-dashboard",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/index.tsx",
    "start": "bun src/index.tsx",
    "cli": "bun src/index.tsx --cli",
    "cli:watch": "bun src/index.tsx --cli --watch",
    "cli:debug": "bun src/index.tsx --cli --debug",
    "build": "bun build src/index.tsx --compile --outfile=agents-dashboard",
    "test": "bun test"
  },
  "dependencies": {
    "@opentui/core": "^0.1.69",
    "@opentui/react": "^0.1.69",
    "react": "^19.0.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^19.0.0",
    "typescript": "^5.7.0"
  }
}
